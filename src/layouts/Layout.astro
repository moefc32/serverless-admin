---
import '../styles/global.css';

import Header from '../components/Header.svelte';
import Footer from '../components/Footer.astro';

const { pageTitle } = Astro.props;
const { pathname } = Astro.url;

const siteTitle = `${import.meta.env.PUBLIC_APP_NAME} - Faizal Chan's Website`;
const isLoginPage = pathname === '/login';
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/png" href="/og.png" />

        <title>
            {pageTitle ? `${pageTitle} | ${siteTitle}` : siteTitle}
        </title>
        <meta name="generator" content={Astro.generator} />

        <script
            src="https://www.googletagmanager.com/gtag/js?id=UA-131278165-1"
            async></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];

            function gtag() {
                dataLayer.push(arguments);
            }

            gtag('js', new Date());
            gtag('config', 'UA-131278165-1');
        </script>
    </head>

    <body
        class="flex flex-col w-full min-h-screen overflow-auto"
        data-theme="light"
    >
        <div style="display: contents">
            {!isLoginPage && <Header client:only="svelte" />}
            <slot />
            {!isLoginPage && <Footer />}
        </div>
    </body>
</html>
